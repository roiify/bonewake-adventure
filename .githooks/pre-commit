#!/usr/bin/env bash
# Block commits that contain secret-shaped strings. Runs gitleaks
# on the staged changes only — fast (~1s) and silent on success.
# If gitleaks isn't installed, the hook prints an install hint but
# does NOT block; install with `brew install gitleaks`.
set -e
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "[pre-commit] gitleaks not installed — install with: brew install gitleaks"
  exit 0
fi
exec gitleaks protect --staged --redact --no-banner
